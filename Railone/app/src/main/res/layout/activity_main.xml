<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        android:background="#FFFFFF">

    <!-- Top header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="@drawable/bg_home_top_bar"
        android:elevation="0dp">

        <!-- Language Toggle Button -->
        <ImageButton
            android:id="@+id/btnLanguage"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_outline"
            android:src="@drawable/ic_language"
            android:padding="9dp"
            android:contentDescription="Language" />

        <!-- RailOne Title with Logo -->
        <LinearLayout
            android:id="@+id/headerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_gravity="center_vertical">

            <ImageView
                android:id="@+id/imgRailOneTitle"
                android:layout_width="220dp"
                android:layout_height="34dp"
                app:srcCompat="@drawable/logo_name" />
        </LinearLayout>

        <!-- Notification Bell with Badge -->
        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp">

            <ImageButton
                android:id="@+id/btnNotification"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_circle_outline"
                android:src="@drawable/ic_bell"
                android:padding="10dp"
                android:contentDescription="Notifications" />

            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:text="3"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_badge"
                android:gravity="center"
                android:layout_gravity="top|end"
                android:layout_marginTop="1dp"
                android:layout_marginEnd="0dp" />
        </FrameLayout>

    </LinearLayout>

    <!-- Main scrollable content -->
    <ScrollView
        android:id="@+id/homeScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HI, Chetan Gupta!"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#1D315D"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Journey Planner"
                android:textStyle="bold"
                android:textSize="34sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#102A5C"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:id="@+id/jpReserved"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp"
                    android:gravity="center_horizontal">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_journey_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/reserve"
                            android:scaleX="1.08"
                            android:scaleY="1.08" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reserved"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#4A4A4A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/jpUnreserved"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center_horizontal">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_journey_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/unserve"
                            android:scaleX="1.08"
                            android:scaleY="1.08" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unreserved"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#4A4A4A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/jpPlatform"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp"
                    android:gravity="center_horizontal">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:background="@drawable/bg_journey_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pletform"
                            android:scaleX="1.08"
                            android:scaleY="1.08" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Platform"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#4A4A4A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="More Offerings"
                android:textStyle="bold"
                android:textSize="34sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#102A5C"
                android:layout_marginBottom="10dp" />

            <!-- More offerings row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/offerSearchTrains"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_offer_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/search"
                            android:scaleX="1.12"
                            android:scaleY="1.12" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search\nTrains"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#45506A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/offerPnrStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_offer_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/pnr"
                            android:scaleX="1.12"
                            android:scaleY="1.12" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PNR\nStatus"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#45506A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/offerCoachPosition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_offer_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/coach"
                            android:scaleX="1.12"
                            android:scaleY="1.12" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coach\nPosition"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#45506A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/offerTrackTrain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="6dp">

                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_offer_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/track"
                            android:scaleX="1.12"
                            android:scaleY="1.12" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Track Your\nTrain"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#45506A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- More offerings row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/cardOrderFood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_offer_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/order"
                            android:scaleX="1.12"
                            android:scaleY="1.12" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order\nFood"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#45506A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardFileRefund"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_offer_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/file"
                            android:scaleX="1.12"
                            android:scaleY="1.12" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="File\nRefund"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#45506A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardRailMadad"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">

                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_offer_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/rail_madad"
                            android:scaleX="1.12"
                            android:scaleY="1.12" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rail\nMadad"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#45506A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardWaves"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="6dp">

                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/bg_offer_image_mask"
                        android:clipToOutline="true">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/go_to"
                            android:scaleX="1.12"
                            android:scaleY="1.12" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Go To\nWAVES"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#45506A"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Do You know -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Do You know?"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#102A5C"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="10dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Card 1: First passenger train -->
                    <LinearLayout
                        android:layout_width="190dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_know_card"
                        android:layout_marginEnd="12dp"
                        android:clipToOutline="true">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="126dp"
                            android:background="@drawable/bg_train_image" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="First ever passenger train was run between Bori Bandar to Thane on April 16, 1853."
                            android:textSize="13sp"
                            android:textColor="#333333"
                            android:padding="10dp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                    <!-- Card 2: Chenab Railway Bridge -->
                    <LinearLayout
                        android:layout_width="190dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_know_card"
                        android:layout_marginEnd="12dp"
                        android:clipToOutline="true">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="126dp"
                            android:background="@drawable/bg_know_image_2" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chenab Railway Bridge in Dharot, Jammu &amp; Kashmir is the World&#39;s highest Railway Bridge."
                            android:textSize="13sp"
                            android:textColor="#333333"
                            android:padding="10dp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                    <!-- Card 3: Bridge piers fact -->
                    <LinearLayout
                        android:layout_width="190dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_know_card"
                        android:layout_marginEnd="4dp"
                        android:clipToOutline="true">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="126dp"
                            android:background="@drawable/bg_know_image_3" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="None of the Railway bridge piers in the world are as tall as Chenab Bridge piers."
                            android:textSize="13sp"
                            android:textColor="#333333"
                            android:padding="10dp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Follow us -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Follow Us On Social Media Platforms"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#102A5C"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="10dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_social_image_mask"
                android:clipToOutline="true"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/homelast" />

                <!-- Dark overlay for contrast -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#30000020" />

                <!-- Social Icons Row centered -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <!-- X (Twitter) -->
                    <FrameLayout
                        android:id="@+id/btnSocialX"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_social_x"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_x" />
                    </FrameLayout>

                    <!-- Facebook -->
                    <FrameLayout
                        android:id="@+id/btnSocialFb"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_social_fb"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_facebook" />
                    </FrameLayout>

                    <!-- Instagram -->
                    <FrameLayout
                        android:id="@+id/btnSocialIg"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_social_ig"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_instagram" />
                    </FrameLayout>

                    <!-- YouTube -->
                    <FrameLayout
                        android:id="@+id/btnSocialYt"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_social_yt"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_youtube" />
                    </FrameLayout>

                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ====== BOTTOM NAVIGATION BAR ====== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:orientation="horizontal"
        android:background="@color/primary_blue"
        android:gravity="center_vertical">

        <!-- Home (selected) -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- My Bookings -->
        <LinearLayout
            android:id="@+id/navBookings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_ticket" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Bookings"
                android:textSize="10sp"
                android:textColor="@color/bottom_nav_unselected"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- You -->
        <LinearLayout
            android:id="@+id/navYou"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
