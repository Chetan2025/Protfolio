<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8EDF2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#1565C0">

        <TextView
            android:id="@+id/btnBackInput"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ticket Data Input"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="36dp"
            android:layout_height="36dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All fields are prefilled. Just edit what you need."
                android:textColor="#5B6470"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etFromStation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="From Station (e.g. MUMBAI CSMT)"
                android:text="GONDIA JN."
                android:inputType="textCapCharacters" />

            <EditText
                android:id="@+id/etToStation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="To Station (e.g. NAGPUR)"
                android:text="NAGPUR"
                android:inputType="textCapCharacters"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etRouteDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Route Distance (e.g. —837 km—)"
                android:text="—130 km—"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etVia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Via"
                android:text="TMR"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etJourneyCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Journey Ticket Code"
                android:text="XS4GEB4030"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etPassengerCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Passenger (e.g. 1 Adult, 0 Child)"
                android:text="1 Adult, 0 Child"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etBookedOn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Booked On (e.g. 10/03/2026 10:56:39)"
                android:text="10/03/2026 10:56:39"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etValidTill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Valid Till (e.g. 10/03/2026 13:56)"
                android:text="10/03/2026 13:56"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etClassFare"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Class/Fare Line"
                android:text="SECOND | SUPERFAST | JOURNEY | ₹80.00"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/etBookingDateLarge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Top Date (e.g. 10 Mar 2026, 10:56)"
                android:text="10 Mar 2026, 10:56"
                android:inputType="text"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/btnApplyTicket"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="#1565C0"
                android:gravity="center"
                android:text="Apply And Open Ticket"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
